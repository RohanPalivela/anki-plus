# Speedrun Android — ONE-SHOT SETUP FOR A NEW MACHINE (macOS, Apple Silicon).
#
# Installs every dependency, clones the two external repos as siblings of this
# fork, points the backend at this fork, builds the Android backend (with
# SpeedrunService) + the AnkiDroid APK, then launches an emulator and installs
# the app. After this finishes once, use ./tools/android-run for day-to-day.
#
# What it installs/changes (this MODIFIES your machine):
#   - Homebrew: openjdk@17, android-commandlinetools
#   - Android SDK packages: platform, build-tools, NDK, emulator, system image
#   - Rust target: aarch64-linux-android
#   - Clones ../Anki-Android and ../Anki-Android-Backend
#   - Creates an emulator (AVD) and installs the app on it
#
# Override with env vars, e.g.:
#   SPEEDRUN_API=34 SPEEDRUN_AVD=my_avd ./tools/android-setup
#   SPEEDRUN_BRANCH=speedrun/m0-m1 ./tools/android-setup
#   ./tools/android-setup --no-run     # build only; skip emulator launch/install

set -euo pipefail

# --- resolve repo layout -----------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FORK_ROOT="$(dirname "$SCRIPT_DIR")"          # .../anki-plus
SIBLINGS="$(dirname "$FORK_ROOT")"            # parent that will hold the clones
ANDROID="$SIBLINGS/Anki-Android"
BACKEND="$SIBLINGS/Anki-Android-Backend"

FORK_BRANCH="${SPEEDRUN_BRANCH:-$(git -C "$FORK_ROOT" rev-parse --abbrev-ref HEAD)}"
API="${SPEEDRUN_API:-35}"
AVD="${SPEEDRUN_AVD:-speedrun_arm64}"
RUN=1
[ "${1:-}" = "--no-run" ] && RUN=0

log() { printf '\n\033[1;36m==> %s\033[0m\n' "$*"; }
die() { printf '\033[1;31merror: %s\033[0m\n' "$*" >&2; exit 1; }

[ "$(uname -s)" = "Darwin" ] || die "this script targets macOS; see docs/speedrun/android.md for Linux/Windows."
command -v brew >/dev/null || die "Homebrew required: https://brew.sh"
command -v git  >/dev/null || die "git required."
command -v rustup >/dev/null || die "rustup required: https://rustup.rs"

# ABI + system image depend on host arch (Apple Silicon => arm64).
if [ "$(uname -m)" = "arm64" ]; then ABI="arm64-v8a"; else ABI="x86_64"; fi
SYSIMG="system-images;android-${API};google_apis;${ABI}"

# --- 1. Homebrew deps --------------------------------------------------------
log "Installing JDK 17 + Android command-line tools (Homebrew)"
brew list openjdk@17 >/dev/null 2>&1 || brew install openjdk@17
brew list --cask android-commandlinetools >/dev/null 2>&1 || brew install --cask android-commandlinetools

# --- 2. environment ----------------------------------------------------------
export JAVA_HOME="$(brew --prefix openjdk@17)/libexec/openjdk.jdk/Contents/Home"
export ANDROID_HOME="${ANDROID_HOME:-/opt/homebrew/share/android-commandlinetools}"
export ANDROID_SDK_ROOT="$ANDROID_HOME"
export PATH="$JAVA_HOME/bin:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$ANDROID_HOME/emulator:$HOME/.cargo/bin:$PATH"
command -v sdkmanager >/dev/null || die "sdkmanager not found after install; check the android-commandlinetools cask."

# --- 3. clone the sibling repos ---------------------------------------------
log "Cloning sibling repos into $SIBLINGS"
[ -d "$ANDROID/.git" ] || git clone https://github.com/ankidroid/Anki-Android.git "$ANDROID"
[ -d "$BACKEND/.git" ] || git clone https://github.com/ankidroid/Anki-Android-Backend.git "$BACKEND"

# --- 4. point the backend's `anki` at THIS fork ------------------------------
log "Pointing backend 'anki' submodule at this fork ($FORK_BRANCH)"
rm -rf "$BACKEND/anki"
git clone -q -b "$FORK_BRANCH" "$FORK_ROOT" "$BACKEND/anki"

# --- 5. SDK packages (NDK/compileSdk read from the backend) ------------------
LIBS="$BACKEND/gradle/libs.versions.toml"
NDK_VERSION="$(grep -E '^\s*ndk\s*=' "$LIBS" | head -1 | sed -E 's/.*"([^"]+)".*/\1/')"
NDK_VERSION="${NDK_VERSION:-29.0.14206865}"
COMPILE_SDK="$(grep -E '^\s*compileSdk\s*=' "$LIBS" | head -1 | sed -E 's/.*"([^"]+)".*/\1/')"
COMPILE_SDK="${COMPILE_SDK:-36}"

log "Installing SDK packages (platform $COMPILE_SDK, NDK $NDK_VERSION, emulator, $SYSIMG)"
yes | sdkmanager --licenses >/dev/null
sdkmanager --install \
    "platform-tools" \
    "platforms;android-${COMPILE_SDK}" \
    "build-tools;${COMPILE_SDK}.0.0" \
    "ndk;${NDK_VERSION}" \
    "emulator" \
    "$SYSIMG"
export ANDROID_NDK_HOME="$ANDROID_HOME/ndk/$NDK_VERSION"
rustup target add aarch64-linux-android

# --- 6. compatibility patch (version drift) ----------------------------------
# Our fork (anki 26.05) exposes a filtered-deck order value AnkiDroid `main`
# (built against 26.05b1) does not handle exhaustively. Add the branch so the
# Kotlin `when` compiles. Extend here if other enums drift.
DECK_KT="$ANDROID/libanki/src/main/java/com/ichi2/anki/libanki/Deck.kt"
if [ -f "$DECK_KT" ] && ! grep -q "RELATIVE_OVERDUENESS" "$DECK_KT"; then
    log "Patching AnkiDroid Deck.kt for enum drift"
    perl -0pi -e 's/(\n(\s*))Order\.UNRECOGNIZED ->/\1Order.RELATIVE_OVERDUENESS -> "Relative overdueness"\1Order.UNRECOGNIZED ->/' "$DECK_KT"
fi

# --- 7. build the backend AAR ------------------------------------------------
log "Building the Android backend AAR (web + arm64 JNI + Kotlin bindings)"
( cd "$BACKEND" && ./build.sh )

# --- 8. configure + build the app -------------------------------------------
log "Building the AnkiDroid APK against the local backend"
printf 'sdk.dir=%s\nlocal_backend=true\n' "$ANDROID_HOME" > "$ANDROID/local.properties"
( cd "$ANDROID" && ./gradlew :AnkiDroid:assembleDebug )

log "Build complete."
echo "  backend AAR : $BACKEND/rsdroid/build/outputs/aar/rsdroid-release.aar"
echo "  app APK     : $ANDROID/AnkiDroid/build/outputs/apk/full/debug/AnkiDroid-full-${ABI}-debug.apk"

# --- 9. launch + install -----------------------------------------------------
if [ "$RUN" -eq 1 ]; then
    log "Launching emulator + installing the app"
    SPEEDRUN_API="$API" SPEEDRUN_AVD="$AVD" "$SCRIPT_DIR/android-run"
else
    echo
    echo "Skipped launch (--no-run). Start it later with: ./tools/android-run"
fi
